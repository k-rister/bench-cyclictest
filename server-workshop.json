{
  "workshop": {
    "schema": {
      "version": "2025.07.25"
    }
  },
  "userenvs": [
    {
      "name": "default",
      "requirements": [
        "stress-ng_src"
      ]
    }
  ],
  "requirements": [
    {
      "name": "stress-ng_src",
      "type": "source",
      "source_info": {
        "url": "https://github.com/ColinIanKing/stress-ng/archive/refs/tags/V0.14.06.tar.gz",
        "filename": "stress-ng.tar.gz",
        "commands": {
          "unpack": "tar -xzf stress-ng.tar.gz",
          "get_dir": "tar -tzf stress-ng.tar.gz  | head -n 1",
          "commands": [
            "make",
            "make install",
            "ldconfig"
          ]
        }
      }
    }
  ]
}
